<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>    
        <record id="wo_technical_comm_manual_view" model="ir.ui.view">
            <field name="name">wo_technical_comm_manual_view</field>
            <field name="model">wo.installation.order.mst</field>
            <field name="inherit_id" ref="qimamhd_wo_v3.wo_installation_order_view" />
            <field name="arch" type="xml">

                    <xpath expr = "//field[@name = 'partner_id']"  position="after">

                        <field name="enter_technical_commission_manual" />
                    </xpath>
                
                    <xpath expr = "//field[@name = 'lines_services']/tree/field[@name = 'technical_name']" position="after">
                          <field name="car_part_flag" invisible="1"/>
                    </xpath>

                    <xpath expr = "//field[@name = 'lines_services']/tree/field[@name = 'car_part_commission']" position="attributes">
                     
                        <attribute name="readonly">0</attribute>

                    </xpath>
                      <!-- <xpath expr = "//field[@name = 'lines_services']/tree/field[@name = 'car_part_commission']" position="attributes">
                     
                        <attribute name="attrs">{'readonly':['|','|','|',('parent.enter_technical_commission_manual','=', False),('parent.is_sale_man_technical', '=', False) , ('parent.state','in',['cancel_order','execute_completed','complete_work'])]}</attribute>

                    </xpath> -->

                    <xpath expr = "//field[@name = 'lines_packages']/tree/field[@name = 'technical_name']" position="after">
                    <field name="car_part_flag" invisible="1"/>

                        <field name="car_part_commission" optional="hide" attrs="{'readonly':['|','|','|',('parent.enter_technical_commission_manual','=', False), ('parent.is_sale_man_technical', '=', False) , ('parent.state','in',['cancel_order','execute_completed','complete_work'])]}"  />

                    </xpath>

               
            </field>
        </record>
    </data>
</odoo> 
