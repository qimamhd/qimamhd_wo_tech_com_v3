<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>    
        <record id="wo_services_header_technical_view" model="ir.ui.view">
            <field name="name">wo_services_header_technical_view</field>
            <field name="model">wo.services.header</field>
            <field name="inherit_id" ref="qimamhd_wo_v3.wo_services_header_view" />
            <field name="arch" type="xml">
                    <xpath expr = "//field[@name = 'discount_type']" position="before">
                          
                            <field name="allow_mgr_cal_commission_priv" invisible="1"/>
                    </xpath>

                    <xpath expr = "//field[@name = 'service_header_lines_id']" position="replace">
                        <field name="service_header_lines_id" delete="0"  create="0" >
                                <tree editable="bottom" string="الاصناف" delete="0" create="0">
                                <button name="modify_lines" string="تعديل بيانات" type="object"   icon="fa-cogs"  width="0.1"
                                        attrs="{'readonly':['|', '|','|','|',('cart_part_selected', '=', False)],'invisible':[('parent.state', 'in', ['cancel_order'])]}"
                                            groups="qimamhd_wo_v3.group_sales_man_priv"
                                        options="{&quot;warn&quot;: true}" />
                               <field name="edit_technial_priv" invisible="1"/>
                                <field name="l_is_read_only_price" invisible="1"/>
                                <field name="l_is_read_only_size" invisible="1"/>
                                <field name="service_type" invisible="1"/>
                                <field name="film_category_id" invisible="1"/>
                                <field name="readonly_car_film_product_id" invisible="1"/>
                                <field name="is_effected_in_inventory" invisible="1"/>

                                <field name="cart_part_selected" string="اختيار" attrs="{'readonly':['|','|','|','|',('parent.sale_order_id','!=', False ),('parent.is_user_technical', '=', True),  ('execute_done_flag', '=', True),('parts_package_flag', '=', True),('parent.state','in',['cancel_order','confirm','execute_request','execute_started','execute_completed','complete_work','sale_order'])]}"/>
                                <field name="cart_part_id" attrs="{'readonly':['|', '|','|','|',('parent.sale_order_id','!=', False ),('cart_part_selected', '=', False),('execute_done_flag', '=', True),('parts_package_flag', '=', True),('parent.state','in',['cancel_order','confirm','execute_request','execute_started','execute_completed','complete_work','sale_order'])]}"  options="{'no_quick_create':True,'no_create_edit':True,'no_open': True,'no_create': True}"/>
                                <field name="car_film_product_id"  options="{'no_quick_create':True,'no_create_edit':True,'no_open': True,'no_create': True}" attrs="{'readonly': ['|','|', '|','|',('readonly_car_film_product_id','=',True), ('parent.sale_order_id','!=', False ),('execute_done_flag', '=', True),('cart_part_selected', '=', False),('parent.state','in',['cancel_order', 'execute_request','execute_completed','complete_work','sale_order'])]}" />
                                <field name="length_qty" attrs="{'column_invisible': [('parent.service_qty_length_weight','=', False)],'readonly':['|','|','|', '|','|',('is_effected_in_inventory','=',False),('parent.sale_order_id','!=', False ),('cart_part_selected', '=', False),('parent.is_sale_man_technical', '=', False) ,('l_is_read_only_size', '=', True) ,('parent.state','in',['draft','cancel_order','execute_completed','complete_work'])]}"/>
                                <field name="width_qty" attrs="{'column_invisible': [('parent.service_qty_length_weight','=', False)],'readonly':['|','|','|', '|','|',('is_effected_in_inventory','=',False),('parent.sale_order_id','!=', False ),('cart_part_selected', '=', False),('parent.is_sale_man_technical', '=', False) ,('l_is_read_only_size', '=', True) ,('parent.state','in',['draft','cancel_order','execute_completed','complete_work'])]}"/>
                                <field name="qty" attrs="{'readonly':['|','|','|', '|','|',('is_effected_in_inventory','=',False),('parent.sale_order_id','!=', False ),('cart_part_selected', '=', False),('parent.is_sale_man_technical', '=', False) ,('l_is_read_only_size', '=', True) ,('parent.state','in',['draft','cancel_order','execute_completed','complete_work'])]}"/>
                                <field name="limpid_product_ids" invisible="1" widget="many2many_tags"/>
                                <field name="limpid_film_product_id"  options="{'no_quick_create':True,'no_create_edit':True,'no_open': True,'no_create': True}" attrs="{'readonly': ['|','|', '|','|',('is_effected_in_inventory','=',False),('parent.sale_order_id','!=', False ),('execute_done_flag', '=', True),('cart_part_selected', '=', False),('parent.state','in',['draft','cancel_order','execute_request','execute_completed','complete_work','sale_order'])]}"  />
                                <field name="cart_part_price" sum="اجمالي السعر" attrs="{'readonly':['|','|','|','|','|','|',('parent.sale_order_id','!=', False ),('parent.is_user_technical', '=', True),('l_is_read_only_price', '=', True) ,('cart_part_selected', '=', False),('execute_done_flag', '=', True),('parts_package_flag', '=', True),('parent.state','in',['cancel_order','confirm','execute_request','execute_started','execute_completed','complete_work','sale_order'])]}" />
                                <field name="worning_msg"  optional="hide"/>
                                 <field name="technical_name" optional="hide"  widget="many2many_tags" options="{'no_quick_create':True,'no_create_edit':True,'no_open': True,'no_create': True}"  attrs="{'readonly':[('edit_technial_priv','=', False)]}"  />
                             
                                <field name="free_qty"  string ="مجاني"  attrs="{'readonly':['|', '|','|','|','|',('parent.sale_order_id','!=', False ),('parent.is_user_technical', '=', True),('cart_part_selected', '=', False),('execute_done_flag', '=', True),('parts_package_flag', '=', True),('parent.state','in',['cancel_order','confirm','execute_request','execute_started','execute_completed','complete_work','sale_order'])]}" />
                                <field name="branch_id_assign" invisible="1"/>
                                <field name="notes"  optional="hide" />
                                <field name="discount_type"  optional="hide" attrs="{'readonly':['|', '|','|','|', '|','|',('parent.sale_order_id','!=', False ),('parent.discount_setting_flag','in', ['final_total']),('parent.is_user_sale_man', '=', False),('cart_part_selected', '=', False),('execute_done_flag', '=', True),('parts_package_flag', '=', True),('parent.state','in',['cancel_order','confirm','execute_request','execute_started','execute_completed','complete_work','sale_order'])]}"/>
                                <field name="discount" string="نسبة الخصم %"  optional="hide"  attrs="{'readonly':['|', '|','|','|','|','|',('parent.sale_order_id','!=', False ),('parent.discount_setting_flag','in', ['final_total']),('parent.is_user_sale_man', '=', False),('cart_part_selected', '=', False),('execute_done_flag', '=', True),('parts_package_flag', '=', True),('parent.state','in',['cancel_order','confirm','execute_request','execute_started','execute_completed','complete_work','sale_order'])]}" />
                                <field name="base_amount"  sum="اجمالي" force_save="1"  />
                                <field name="discount_amount"  sum="اجمالي الخصم" readonly="1" force_save="1" />
                                <field name="car_part_commission"   readonly="1" force_save="1"/>
                                <field name="execute_done_flag"  invisible="1" />
                                <field name="parts_package_flag"  invisible="1" />
                      
                            </tree>
                        </field>
                    </xpath>

                   
            </field>
        </record>
    </data>
</odoo> 
